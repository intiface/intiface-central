{
  "id": "desktop-devices-window",
  "title": "Desktop Devices tab with simulated devices",
  "mode": "widget",
  "viewport": {
    "width": 1440,
    "height": 900
  },
  "pixelRatio": 2,
  "theme": "light",
  "presentation": "window",
  "background": "transparent",
  "window": {
    "width": 900,
    "height": 650
  },
  "entrypoint": "desktopStartup",
  "fixture": {
    "engine": "clientConnected",
    "clientName": "Docs Demo Client",
    "navigationPage": "deviceControl",
    "useSideNavigationBar": true,
    "devices": [
      {
        "id": "single-vibrator",
        "kind": "single-vibrator",
        "displayName": "Alpha Single Vibrator",
        "index": 0,
        "connected": true
      },
      {
        "id": "double-vibrator",
        "kind": "double-vibrator",
        "displayName": "Beta Double Vibrator",
        "index": 1,
        "connected": true
      },
      {
        "id": "stroker",
        "kind": "stroker",
        "displayName": "Gamma Stroker",
        "index": 2,
        "connected": true
      }
    ]
  },
  "callouts": [
    {
      "id": "device-status",
      "target": {
        "key": "docs.deviceCard.0.status"
      },
      "label": "Device Status",
      "placement": "left",
      "highlightPadding": 0
    },
    {
      "id": "device-info",
      "target": {
        "key": "docs.deviceCard.1.info"
      },
      "label": "Device Info",
      "placement": "right",
      "highlightPadding": 0
    },
    {
      "id": "connection-info",
      "target": {
        "key": "docs.deviceCard.1.connectionInfo"
      },
      "label": "Connection Info",
      "placement": "left"
    },
    {
      "id": "observability",
      "target": {
        "key": "docs.deviceCard.1.observability"
      },
      "label": "Observability",
      "placement": "bottom",
      "highlightPadding": 0
    }
  ]
}
