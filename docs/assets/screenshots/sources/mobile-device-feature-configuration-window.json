{
  "id": "mobile-device-feature-configuration-window",
  "title": "Mobile device feature configuration panel",
  "mode": "widget",
  "viewport": {
    "width": 1040,
    "height": 790
  },
  "pixelRatio": 2,
  "theme": "light",
  "presentation": "window",
  "background": "transparent",
  "window": {
    "width": 390,
    "height": 633
  },
  "entrypoint": "mobileStartup",
  "fixture": {
    "engine": "stopped",
    "navigationPage": "deviceControl",
    "useSideNavigationBar": false,
    "devices": [
      {
        "id": "double-vibrator",
        "kind": "double-vibrator",
        "displayName": "Beta Double Vibrator",
        "index": 1,
        "connected": false
      }
    ],
    "actions": [
      {
        "tapText": "Beta Double Vibrator"
      },
      {
        "tapText": "Feature: Left vibrator"
      },
      {
        "ensureVisibleText": "Feature: Right vibrator"
      }
    ]
  },
  "callouts": [
    {
      "id": "feature-configuration",
      "target": {
        "key": "docs.deviceDetail.featureConfiguration.0"
      },
      "label": "Feature Configuration",
      "placement": "right",
      "highlightPadding": 0,
      "markerOnly": true
    }
  ]
}
